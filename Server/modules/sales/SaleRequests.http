@variantId = 6a2552c8e287dc0cf6e6ab62

### Get all sales
GET {{baseUrl}}/sales
Authorization: Bearer {{token}}

### Get sale by id
GET {{baseUrl}}/sales/{{saleId}}
Authorization: Bearer {{token}}

### Create sale using the variant selling price
POST {{baseUrl}}/sales
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "paymentStatus": "Paid",
  "discount": 500,
  "items": [
    {
      "variantId": "{{variantId}}",
      "quantity": 3
    }
  ]
}

### Create sale with explicit unit price
POST {{baseUrl}}/sales
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "paymentStatus": "Pending",
  "discount": 0,
  "items": [
    {
      "variantId": "{{variantId}}",
      "quantity": 2,
      "unitPrice": 72000
    }
  ]
}

### Process sale return and sync inventory
POST {{baseUrl}}/sales/{{saleId}}/returns
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "notes": "Customer returned one unit",
  "items": [
    {
      "variantId": "{{variantId}}",
      "quantity": 1
    }
  ]
}
