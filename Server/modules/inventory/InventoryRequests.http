@baseUrl = http://localhost:5001/api
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2YTI0ZGQxMTNlM2VmZWM3NWY3NmZkOTIiLCJpYXQiOjE3ODA4MzU4MjIsImV4cCI6MTc4MTQ0MDYyMn0.yTtjm_nNwWjK2BDGKWZJ6y1VEBhAUug66LxzhN_cjqU
@variantId = 6a2552c8e287dc0cf6e6ab62

### Get current inventory
GET {{baseUrl}}/inventory
Authorization: Bearer {{token}}

### Stock in from purchase
POST {{baseUrl}}/inventory/stock-in
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variantId": "{{variantId}}",
  "quantity": 10,
  "type": "PURCHASE",
  "referenceId": "PO-1001",
  "notes": "Initial supplier purchase"
}

### Stock in from customer return
POST {{baseUrl}}/inventory/stock-in
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variantId": "{{variantId}}",
  "quantity": 1,
  "type": "RETURN",
  "referenceId": "RET-1001",
  "notes": "Returned item added back to stock"
}

### Stock out from sale
POST {{baseUrl}}/inventory/stock-out
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variantId": "{{variantId}}",
  "quantity": 2,
  "type": "SALE",
  "referenceId": "SALE-1001",
  "notes": "Customer sale"
}

### Stock out from manual adjustment
POST {{baseUrl}}/inventory/stock-out
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variantId": "{{variantId}}",
  "quantity": 1,
  "type": "ADJUSTMENT",
  "referenceId": "ADJ-1001",
  "notes": "Damaged item removed from inventory"
}
